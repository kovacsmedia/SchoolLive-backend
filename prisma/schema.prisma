// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  ORG_ADMIN
  TEACHER
  OPERATOR
  PLAYER
}

enum DeviceClass {
  SPEAKER
  DISPLAY
  MULTI
}

enum DeviceAuthType {
  KEY
  JWT
}

enum MessageType {
  TTS
  AUDIO_FILE
  YOUTUBE
  PLAYLIST
}

enum TargetType {
  DEVICE
  GROUP
  ORG_UNIT
  ALL
}

enum CommandStatus {
  QUEUED
  SENT
  ACKED
  FAILED
}

enum RadioScheduleStatus {
  PENDING
  DISPATCHED
  CANCELLED
}

enum OtaStatus {
  UP_TO_DATE
  PENDING
  DOWNLOADING
  INSTALLING
  FAILED
  ROLLBACK
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  address        String?
  directorName   String?
  directorPhone  String?
  directorEmail  String?
  eduId          String?
  messageTemplates MessageTemplate[]
  bellTemplates    BellScheduleTemplate[]
  bellCalendar     BellCalendarDay[]
  bellSoundFiles   BellSoundFile[]
  bellScheduleLock BellScheduleLock?
  orgUnits  OrganizationalUnit[]
  users     User[]
  devices   Device[]
  groups    DeviceGroup[]
  messages  Message[]
  commands  DeviceCommand[]
  radioFiles       RadioFile[]
  radioSchedules   RadioSchedule[]
  youtubePlaylists YoutubePlaylist[]

  @@index([isActive])
}

model OrganizationalUnit {
  id        String  @id @default(uuid())
  tenantId  String
  name      String
  parentId  String?

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    OrganizationalUnit? @relation("OrgUnitTree", fields: [parentId], references: [id])
  children  OrganizationalUnit[] @relation("OrgUnitTree")

  users     User[]
  devices   Device[]

  @@index([tenantId])
  @@index([tenantId, parentId])
  @@unique([tenantId, name])
}

model User {
  id        String   @id @default(uuid())
  tenantId  String?
  orgUnitId String?
  messageTemplates MessageTemplate[]
  email        String   @unique
  displayName  String?
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  bellScheduleLock BellScheduleLock?
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?

  trustedDeviceHash  String?
  trustedDeviceSetAt DateTime?

  lastLoginAt DateTime?
  createdAt   DateTime @default(now())

  tenant   Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  orgUnit  OrganizationalUnit? @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)

  messages Message[] @relation("CreatedBy")
  devices  Device[]

  radioFiles     RadioFile[]     @relation("RadioFileCreatedBy")
  radioSchedules RadioSchedule[] @relation("RadioScheduleCreatedBy")
  youtubePlaylists YoutubePlaylist[] @relation("YoutubePlaylistCreatedBy")
  firmwareReleases FirmwareRelease[] @relation("FirmwareCreatedBy")

  @@index([tenantId])
  @@index([role])
  @@index([isActive])
}

model Device {
  id            String   @id @default(uuid())
  tenantId      String
  orgUnitId     String?

  serialNumber    String? @unique
  installCodeHash String?

  name String

  authType      DeviceAuthType @default(KEY)
  deviceKeyHash String?

  clientId String?
  userId   String?

  firmwareVersion String?
  ipAddress       String?

  lastSeenAt DateTime?
  online     Boolean  @default(false)

  volume Int     @default(5)
  muted  Boolean @default(false)

  statusPayload Json?

  createdAt DateTime @default(now())
  deviceClass DeviceClass @default(SPEAKER)

  // Hardver modell – firmware célzáshoz
  hwModel      String?   @default("ESP32_S3")
  // pl: ESP32_WROOM, ESP32_S3, ESP32_S3_N16R8, DISPLAY_S3, MULTI_S3

  // OTA frissítési állapot
  otaStatus    OtaStatus @default(UP_TO_DATE)
  otaProgress  Int       @default(0)
  otaVersion   String?
  otaUpdatedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orgUnit OrganizationalUnit? @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  groupMembers      DeviceGroupMember[]
  commands          DeviceCommand[]
  provisionSessions DeviceProvisionSession[]

  @@index([tenantId])
  @@index([tenantId, online])
  @@index([tenantId, lastSeenAt])
  @@index([userId])
  @@unique([tenantId, name])
  @@unique([tenantId, clientId])
}

model DeviceGroup {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members DeviceGroupMember[]

  @@index([tenantId])
  @@unique([tenantId, name])
}

model DeviceGroupMember {
  groupId  String
  deviceId String

  group  DeviceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  device Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([groupId, deviceId])
  @@index([deviceId])
}

model Message {
  id          String      @id @default(uuid())
  tenantId    String
  type        MessageType
  title       String?
  text        String?
  fileUrl     String?
  voice       String?
  scheduledAt DateTime?
  playedAt    DateTime?

  targetType TargetType
  targetId   String?

  createdById String
  createdAt   DateTime @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User    @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  commands  DeviceCommand[]

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, targetType])
  @@index([tenantId, createdAt])
}

model MessageTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  name      String
  text      String
  voice     String   @default("anna")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model DeviceCommand {
  id        String   @id @default(uuid())
  tenantId  String
  deviceId  String
  messageId String?
  payload   Json

  status   CommandStatus @default(QUEUED)
  queuedAt DateTime      @default(now())
  sentAt   DateTime?
  ackedAt  DateTime?
  error    String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device  Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([deviceId])
  @@index([tenantId, status])
  @@index([tenantId, queuedAt])

  retryCount Int @default(0)
  maxRetries Int @default(3)
  lastError  String?
}

model DeviceProvisionSession {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  deviceId  String
  tenantId  String?
  wifiHidden   Boolean @default(false)
  wifiSecurity String  @default("WPA2_PERSONAL")
  wifiUser     String  @default("")

  name         String
  wifiSsid     String
  wifiPassword String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  pendingDeviceKey String?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([expiresAt])
}

model PendingDevice {
  id              String   @id @default(uuid())
  mac             String   @unique
  ipAddress       String?
  firmwareVersion String?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  clientId        String?
  userId          String?
  userAgent       String?

  @@index([lastSeenAt])
}

enum BellType {
  MAIN
  SIGNAL
}

model BellScheduleTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bells        BellEntry[]
  calendarDays BellCalendarDay[]

  @@index([tenantId])
  @@unique([tenantId, name])
}

model BellEntry {
  id         String   @id @default(uuid())
  templateId String
  hour       Int
  minute     Int
  type       BellType
  soundFile  String

  template BellScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model BellCalendarDay {
  id         String   @id @default(uuid())
  tenantId   String
  date       DateTime @db.Date
  isHoliday  Boolean  @default(false)
  templateId String?

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template BellScheduleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, date])
  @@unique([tenantId, date])
}

model BellSoundFile {
  id        String   @id @default(uuid())
  tenantId  String
  filename  String
  sizeBytes Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@unique([tenantId, filename])
}

model BellScheduleLock {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  userId    String   @unique
  lockedAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RadioFile {
  id           String   @id @default(uuid())
  tenantId     String
  filename     String
  originalName String
  sizeBytes    Int
  durationSec  Int?
  fileUrl      String
  createdById  String
  createdAt    DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User            @relation("RadioFileCreatedBy", fields: [createdById], references: [id])
  schedules RadioSchedule[]
  youtubePlaylists YoutubePlaylist[]

  @@unique([tenantId, filename])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model RadioSchedule {
  id           String              @id @default(uuid())
  tenantId     String
  radioFileId  String
  targetType   TargetType
  targetId     String?
  scheduledAt  DateTime
  status       RadioScheduleStatus @default(PENDING)
  dispatchedAt DateTime?
  createdById  String
  createdAt    DateTime            @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  radioFile RadioFile @relation(fields: [radioFileId], references: [id], onDelete: Cascade)
  createdBy User      @relation("RadioScheduleCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@index([status, scheduledAt])
}

enum YoutubePlaylistStatus {
  IDLE
  BUILDING
  DONE
  ERROR
}

model YoutubePlaylist {
  id          String                @id @default(uuid())
  tenantId    String
  name        String
  status      YoutubePlaylistStatus @default(IDLE)
  errorMsg    String?
  radioFileId String?               @unique
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User                @relation("YoutubePlaylistCreatedBy", fields: [createdById], references: [id])
  radioFile RadioFile?          @relation(fields: [radioFileId], references: [id])
  items     YoutubePlaylistItem[]

  @@index([tenantId])
}

model YoutubePlaylistItem {
  id         String @id @default(uuid())
  playlistId String
  youtubeUrl String
  title      String?
  sortOrder  Int

  playlist YoutubePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
}

model FirmwareRelease {
  id          String   @id @default(uuid())
  version     String   @unique
  filename    String
  fileUrl     String
  sizeBytes   Int
  sha256      String
  notes       String?
  mandatory   Boolean  @default(false)
  targetClass String   @default("ALL")
  createdAt   DateTime @default(now())
  createdById String

  createdBy User @relation("FirmwareCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdAt])
}